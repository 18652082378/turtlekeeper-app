{
  "name": "turtlekeeper-ios-app",
  "version": "1.0.0",
  "private": true,
  "description": "ShellNote iOS cloud build package",
  "scripts": {
    "start": "node server/server.js",
    "build": "node scripts/build-web.js",
    "test:backup-restore": "node scripts/test-backup-restore.js",
    "verify:backup": "node scripts/restore-server-backup.js",
    "cap:add:ios": "npm run build && npx cap add ios",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:open:ios": "npm run build && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "8.4.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "8.4.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
