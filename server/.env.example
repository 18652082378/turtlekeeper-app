# Copy this file to .env on your server, then fill real values.
SMS_PROVIDER=aliyun-pnvs
SMS_MOCK=false

# Aliyun RAM AccessKey. Do not commit real secrets to GitHub.
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# Aliyun Phone Number Verification Service SMS authentication values.
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=100001

# Gift template 100001 uses ${code} and ${min}.
ALIYUN_SMS_TEMPLATE_PARAM_KEY=code
ALIYUN_SMS_TEMPLATE_MINUTES=5
ALIYUN_SMS_CODE_LENGTH=6
ALIYUN_SMS_VALID_TIME=300
ALIYUN_SMS_COUNTRY_CODE=86

# Keep 127.0.0.1 when using Nginx reverse proxy.
HOST=127.0.0.1
PORT=8787
